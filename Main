local pickaxestats_module = require(game.ReplicatedStorage.Modules.PickaxeStats)
local orestats_module = require(game.ReplicatedStorage.Modules.OreStats)
local getnextpickaxe_module = require(game.ReplicatedStorage.Modules.GetNextPickaxe)
local events = game.ReplicatedStorage.Events

local playerdatas = {}
local templatedata = {
	Pickaxe = "Wooden Pickaxe",
	Coins = 0,
	Backpack = {},
}

local playercooldowns = {}

local function findtool(player : Player)
	local char = player.Character or player.CharacterAdded:Wait()
	
	for i, v in char:GetChildren() do
		if v:IsA("Tool") then
			return v
		end
	end
	
	return player.Backpack:FindFirstChildWhichIsA("Tool")
end

game.Players.PlayerAdded:Connect(function(plr)
	playerdatas[plr.UserId] =  table.clone(templatedata)
end)

events.SellOres.OnServerEvent:Connect(function(plr)
	local data = playerdatas[plr.UserId]
	local totalcoins = 0
	
	for _, v in data.Backpack do
		totalcoins += orestats_module[v].Value
	end
	
	data.Backpack = {}
	data.Coins += totalcoins
	events.UpdateData:FireClient(plr, playerdatas[plr.UserId])
end)

events.UpgradePickaxe.OnServerEvent:Connect(function(plr)
	local data = playerdatas[plr.UserId]
	local pickaxe = getnextpickaxe_module(data.Pickaxe)
	
	if pickaxe and data.Coins >= pickaxestats_module[pickaxe].Cost then
		data.Coins -= pickaxestats_module[pickaxe].Cost
		data.Pickaxe = pickaxe
		
		local tool : Tool = findtool(plr)
		tool.Handle:Destroy()
		local handle : MeshPart = game.ReplicatedStorage.Pickaxes[pickaxe]:Clone()
		handle.Parent = tool
		handle.Name = "Handle"
		
		events.UpdateData:FireClient(plr, data)
	end
end)

events.MineOre.OnServerEvent:Connect(function(plr, ore : Part)
	if playercooldowns[plr.UserId] then return end
	local char = plr.Character or plr.CharacterAdded:Wait()
	
	if (char:GetPivot().Position - ore.Position).Magnitude > 25 then return end
	
	playercooldowns[plr.UserId] = true
	ore.Health.Value -= pickaxestats_module[playerdatas[plr.UserId].Pickaxe].Damage
	
	if ore.Health.Value <= 0 then
		table.insert(playerdatas[plr.UserId].Backpack, ore.Name)	
		events.UpdateData:FireClient(plr, playerdatas[plr.UserId])
		task.delay(1, function()
			ore:Destroy()
		end)
	end
	
	task.wait(pickaxestats_module[playerdatas[plr.UserId].Pickaxe].Cooldown)
	playercooldowns[plr.UserId] = nil
end)
